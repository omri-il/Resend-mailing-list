      "id": "edda4705-0a2b-4eab-beb6-34ca52ecc55d",
      "name": "Telegram Preview",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2420,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const config = $('Config').first().json;\nconst items = $input.all();\nconst changed = items.filter(i => i.json.changed);\nconst batchSize = parseInt(config.batch_size) || 190;\nconst limited = changed.slice(0, batchSize);\n\nreturn limited.map((item, index) => ({\n  json: {\n    ...item.json,\n    _index: index + 1,\n    _total: limited.length\n  }\n}));"
      },
