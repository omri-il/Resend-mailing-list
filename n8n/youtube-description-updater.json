        "jsCode": "const config = $('Config').first().json;\nconst report = 'UPDATE COMPLETE\\n\\n'\n  + 'Operation: ' + config.operation + '\\n'\n  + 'Check YouTube Studio to verify.';\n\nreturn [{ json: { report } }];"
      },
