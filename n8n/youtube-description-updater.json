      "id": "8c1b783b-9bde-4bb9-84b9-f39ef20cac99",
      "name": "Get Channel",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const channel = $input.first().json;\nconst playlistId = channel.items[0].contentDetails.relatedPlaylists.uploads;\nreturn [{ json: { playlistId } }];"
      },
      "id": "f01f612a-25d4-435e-8bda-0683dd0dda25",
      "name": "Extract Playlist ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.googleapis.com/youtube/v3/playlistItems",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "part",
              "value": "snippet"
            },
            {
              "name": "playlistId",
              "value": "={{ $json.playlistId }}"
            },
            {
              "name": "maxResults",
              "value": "50"
            }
          ]
        },
        "options": {}
      },
      "id": "016328e3-00f7-41ef-87a0-080a5ae045b4",
      "name": "Get All Playlist Items",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst videoIds = [];\n\nfor (const page of allItems) {\n  const items = page.json.items || [];\n  for (const item of items) {\n    videoIds.push(item.snippet.resourceId.videoId);\n  }\n}\n\n// Batch into groups of 50 for the videos.list API\nconst batches = [];\nfor (let i = 0; i < videoIds.length; i += 50) {\n  batches.push({ json: { ids: videoIds.slice(i, i + 50).join(',') } });\n}\n\nreturn batches;"
      },
      "id": "c97a5dba-63b5-4d3f-80b8-8a91e7e71722",
      "name": "Extract Video IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.googleapis.com/youtube/v3/videos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "part",
              "value": "snippet"
            },
            {
              "name": "id",
              "value": "={{ $json.ids }}"
            }
          ]
        },
        "options": {}
      },
      "id": "8a5a1adb-2346-4730-87cf-4adf861e1982",
      "name": "Get Video Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const allPages = $input.all();\nconst allVideos = [];\n\nfor (const page of allPages) {\n  const items = page.json.items || [];\n  for (const video of items) {\n    allVideos.push({\n      json: {\n        videoId: video.id,\n        title: video.snippet.title,\n        description: video.snippet.description || '',\n        snippet: {\n          title: video.snippet.title,\n          description: video.snippet.description || '',\n          categoryId: video.snippet.categoryId,\n          tags: video.snippet.tags || [],\n          defaultLanguage: video.snippet.defaultLanguage || '',\n          defaultAudioLanguage: video.snippet.defaultAudioLanguage || ''\n        }\n      }\n    });\n  }\n}\n\nreturn allVideos;"
      },
      "id": "1b383032-d052-42e6-8063-cd6d2f679529",
      "name": "Flatten Videos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const config = $('Config').first().json;\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const video = item.json;\n  const currentDesc = video.description || '';\n  let newDesc = currentDesc;\n  let skipped = false;\n  let skipReason = '';\n\n  if (config.skip_if_contains && currentDesc.includes(config.skip_if_contains)) {\n    skipped = true;\n    skipReason = 'already contains marker text';\n  }\n\n  if (!skipped) {\n    switch (config.operation) {\n      case 'append':\n        newDesc = currentDesc + config.text_to_add;\n        break;\n      case 'prepend':\n        newDesc = config.text_to_add + currentDesc;\n        break;\n      case 'replace':\n        if (config.find_text) {\n          newDesc = currentDesc.replaceAll(config.find_text, config.replace_text);\n        }\n        break;\n    }\n\n    if (newDesc.length > 5000) {\n      skipped = true;\n      skipReason = 'description would exceed 5000 chars';\n      newDesc = currentDesc;\n    }\n  }\n\n  results.push({\n    json: {\n      videoId: video.videoId,\n      title: video.title,\n      currentDescription: currentDesc,\n      newDescription: newDesc,\n      changed: currentDesc !== newDesc,\n      skipped,\n      skipReason,\n      snippet: { ...video.snippet, description: newDesc }\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "82489c9c-2d29-42c2-b82b-6a0a04b60ed0",
      "name": "Modify Descriptions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        0
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 1
                },
                "conditions": [
                  {
                    "leftValue": "={{ $(\"Config\").item.json.mode }}",
                    "rightValue": "dry_run",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    },
                    "id": "cond-dry-run"
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 1
                },
                "conditions": [
                  {
                    "leftValue": "={{ $(\"Config\").item.json.mode }}",
                    "rightValue": "update",
                    "operator": {
                      "type": "string",
                      "operation": "equals",
                      "name": "filter.operator.equals"
                    },
                    "id": "cond-update"
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "a8dfec70-ccbb-40d1-af88-92d77277f34e",
      "name": "Dry Run?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        1980,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst config = $('Config').first().json;\nconst changed = items.filter(i => i.json.changed);\nconst skipped = items.filter(i => i.json.skipped);\nconst unchanged = items.filter(i => !i.json.changed && !i.json.skipped);\n\nlet report = 'DRY RUN REPORT\\n\\n';\nreport += 'Operation: ' + config.operation + '\\n';\nreport += 'Total videos: ' + items.length + '\\n';\nreport += 'Would change: ' + changed.length + '\\n';\nreport += 'Skipped: ' + skipped.length + '\\n';\nreport += 'Unchanged: ' + unchanged.length + '\\n\\n';\n\nif (changed.length > 0) {\n  report += '--- First 5 Changes ---\\n\\n';\n  for (const item of changed.slice(0, 5)) {\n    report += 'Video: ' + item.json.title + '\\n';\n    report += 'Before: ' + item.json.currentDescription.substring(0, 80) + '...\\n';\n    report += 'After: ' + item.json.newDescription.substring(0, 80) + '...\\n\\n';\n  }\n}\n\nreport += 'Set mode to update and run again to apply.';\n\nreturn [{ json: { report } }];"
      },
